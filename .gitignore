# This repo versions ONLY the translation memory (locale/**/*.po) and the
# config/scripts that drive the i18n build. Everything below is regenerated
# by the docs build (from the pyvista submodule) and must never be committed.
# Committing it caused ~2.5 GB of binary history bloat (2.17 GB of PNGs alone).

# Rendered doc / gallery binaries
*.png
*.gif
*.mp4
*.webp
*.jpeg
*.jpg
*.ipynb
*.md5
*.doctree
*.pickle
*.vtksz

# Stale vendored pyvista doc output (built from the submodule, never sourced here)
examples/
images/
api/

# gettext build tree (regenerated by locale/update.sh every run)
locale/pot/
locale/jupyter_execute/
locale/examples/

# Example data dumps
locale/ant.pkl
locale/ant.vtk
locale/my_partitions.vtpd
locale/my_partitions/

# Transifex CLI binary + build output
tx
_build/
_test_build/
pyvista/doc/source/api/examples/dataset-gallery/
