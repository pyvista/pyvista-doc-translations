"  margin-block-start: 0;\n"
"  margin-block-end: 0;\n"
"  list-style: none;\n"
"}\n"
"\n"
".pv-section-item {\n"
"  display: contents;\n"
"}\n"
"\n"
"/* Hidden checkbox for expand/collapse */\n"
