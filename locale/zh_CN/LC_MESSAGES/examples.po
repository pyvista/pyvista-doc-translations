"}\n"
"\n"
".pv-section-item > input:enabled + label:hover {\n"
"  color: var(--pv-font-color0);\n"
"}\n"
"\n"
"/* Section summary (left column label) */\n"
".pv-section-summary {\n"
"  grid-column: 1;\n"
"  color: var(--pv-font-color2);\n"
"  font-weight: 500;\n"
"  white-space: nowrap;\n"
"}\n"
"\n"
".pv-section-summary > span {\n"
